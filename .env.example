DB_HOST=localhost
DB_PORT=5435
DB_NAME=chatbotdb
DB_USER=admin
DB_PASSWORD=admin123

SECURITY_SERVICE_URL=http://security-service:5001
ADMIN_SERVICE_URL=http://administration-service:5002
TUTORIAS_SERVICE_URL=http://tutorias-service:5003

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

INTERNAL_TOKEN=change_me_in_production

# Motor de IA
AI_ENGINE=qwen

# Configuración Ollama / Agente LLM
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=30
OLLAMA_MAX_TOOL_ITERATIONS=3

# RAG
RAG_TOP_K=5
RAG_CANDIDATES=20
RAG_MIN_SCORE=0.35
RAG_VECTOR_WEIGHT=0.80
RAG_TEXT_WEIGHT=0.20
